# ── clawd-web server ─────────────────────────────────────────────────────────
PORT=7800

# ── OpenClaw gateway (auto-detected from ~/.openclaw/openclaw.json if blank) ─
# Override if your gateway lives elsewhere or uses a different token.
OPENCLAW_WS_URL=
OPENCLAW_TOKEN=
OPENCLAW_SESSION_KEY=agent:clawd:main

# ── Bankr LLM API key (for auto tab titles) ───────────────────────────────────
BANKR_LLM_KEY=

# ── OpenAI key (fallback TTS — gpt-4o-mini-tts onyx voice, ~2s latency) ──────
# Without ElevenLabs, this powers the 🔊 toggle. Without either, browser TTS.
OPENAI_API_KEY=

# ── ElevenLabs (preferred TTS — Flash v2.5, ~200ms TTFB) ─────────────────────
# When set, takes priority over OPENAI_API_KEY for the 🔊 toggle.
# Default voice is Brian (deep American male). Browse the public voice library
# at https://elevenlabs.io/app/voice-library and paste another voice ID below
# to swap.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb
