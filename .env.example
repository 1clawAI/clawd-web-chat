# ── clawd-web server ─────────────────────────────────────────────────────────
PORT=7800

# ── Hermes agent (OpenAI-compatible API server) ──────────────────────────────
# Point at your Hermes box's API server. Enable it on that machine via
# ~/.hermes/.env: API_SERVER_ENABLED=true and API_SERVER_KEY=<key>, then run
# `hermes gateway`. The bearer key grants Hermes's FULL toolset (incl. terminal),
# so it lives here server-side and is never sent to the browser.
HERMES_BASE_URL=https://your-hermes-host:8642
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
# Optional: a Google Sheet (CSV export) of recent 1Claw updates. When set, asking
# "what's new with 1Claw?" feeds the newest rows to the agent so it answers from
# the real list. Publish-to-web / share "anyone with link", then use the CSV URL:
#   https://docs.google.com/spreadsheets/d/<ID>/export?format=csv
ONECLAW_SHEET_CSV_URL=

# Optional personality nudge prepended as a system message on the main chat —
# lets a little dry, deadpan wit surface occasionally. Leave unset for the
# built-in subtle default, or set HERMES_PERSONA="" to disable entirely.
# HERMES_PERSONA=
# Optional: pin the hostname to a fixed IP (e.g. a Tailscale 100.x address) when
# MagicDNS / system DNS can't resolve it. TLS still validates the hostname above.
HERMES_RESOLVE_IP=

# ── Bankr LLM API key (cascade fallback for auto tab titles + filler) ─────────
# The cascade is: Hermes (titles only) → bankr → venice → anthropic. Filler
# stall-talk stays on these fast models — the full Hermes agent is too slow for
# sub-second fillers.
BANKR_LLM_KEY=

# ── Venice fallback (used if bankr times out / 5xx) ──────────────────────────
# Sign up at https://venice.ai for an OpenAI-compatible inference key.
VENICE_API_KEY=

# ── Anthropic direct (ultimate fallback — used if bankr AND venice both fail) ─
# Grab a key at https://console.anthropic.com. Costs more but never fails.
ANTHROPIC_API_KEY=

# ── OpenAI key (fallback TTS — gpt-4o-mini-tts onyx voice, ~2s latency) ──────
# Without ElevenLabs, this powers the 🔊 toggle. Without either, browser TTS.
OPENAI_API_KEY=

# ── ElevenLabs (preferred TTS — Flash v2.5, ~200ms TTFB) ─────────────────────
# When set, takes priority over OPENAI_API_KEY for the 🔊 toggle.
# Default voice is Brian (deep American male). Browse the public voice library
# at https://elevenlabs.io/app/voice-library and paste another voice ID below
# to swap.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb
